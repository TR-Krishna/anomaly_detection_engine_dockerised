# EcoSentinel Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ?? API Connection ?????????????????????????????????????????
# Base URL for the EcoSentinel backend (FastAPI).
# No trailing slash.
VITE_API_BASE_URL=http://localhost:8000

# ?? Optional: Polling ??????????????????????????????????????
# Max number of polling attempts before showing timeout message.
# At 3s per attempt, 20 attempts = 60s timeout window.
# VITE_POLL_MAX_ATTEMPTS=20
# VITE_POLL_INTERVAL_MS=3000
